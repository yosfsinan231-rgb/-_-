    "By default, localized titles for the app won't be changed, however this option overrides it." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standardmäßig werden lokalisierte Titel der App nicht geändert, diese Option überschreibt dies jedoch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By default, localized titles for the app won't be changed, however this option overrides it."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Di default, i titoli tradotti delle app non cambieranno, ma questa opzione lo sostituisce."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Domyślnie tłumaczone tytuły aplikacji nie będą zmieniane, jednak ta opcja to nadpisuje."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varsayılan olarak, uygulamanın yerelleştirilmiş başlıkları değiştirilmeyecektir, ancak bu seçenek bunu geçersiz kılar."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
